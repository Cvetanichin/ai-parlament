# Copy to supabase/.env.local and fill in real values before running:
#   supabase functions serve --env-file supabase/.env.local
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by `supabase functions serve` for the local stack — do not
# set them here.

# llmGateway.ts — at least one of these enables real LLM calls; with neither
# set, llmGateway.ts falls back to its mock provider.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# embeddingClient.ts / embedding-pipeline-run — required only for the
# embedding pipeline function.
OPENAI_API_KEY=

# workflow-*-run functions — "shadow" (default) logs governance decisions
# without enforcing them; "enforced" applies them for real.
GOVERNANCE_MODE=shadow
